{
    "cleanUrls": true,
    "headers": [
        {
            "source": "/.well-known/apple-app-site-association",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/json"
                }
            ]
        },
        {
            "source": "/apple-app-site-association",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/json"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/delete-account",
            "destination": "/delete-account.html"
        },
        {
            "source": "/event/:id",
            "destination": "/api/og/:id"
        },
        {
            "source": "/((?!api|_next|assets|.*\\..*).*)",
            "destination": "/"
        }
    ]
}
